{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ACE Desktop",
  "version": "0.1.5",
  "identifier": "com.yatsuiii.ace",
  "build": {
    "beforeDevCommand": "npm --prefix ../frontend run dev",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ACE",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "API Causality Engine desktop",
    "longDescription": "Stateful API workflow testing — desktop shell"
  }
}
