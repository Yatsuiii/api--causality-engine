{
  "info": {
    "name": "ACE Import Test — Basic",
    "_postman_id": "ace-test-basic-001",
    "description": "Basic collection to test ACE import. No scripts, no auth complexity.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://jsonplaceholder.typicode.com"
    }
  ],
  "item": [
    {
      "name": "Get Post",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/posts/1",
          "host": ["{{base_url}}"],
          "path": ["posts", "1"]
        },
        "description": "Fetch a single post by ID"
      }
    },
    {
      "name": "Get Posts with Query Param",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/posts?userId=1",
          "host": ["{{base_url}}"],
          "path": ["posts"],
          "query": [
            {
              "key": "userId",
              "value": "1"
            }
          ]
        },
        "description": "Fetch posts filtered by userId query param"
      }
    },
    {
      "name": "Create Post",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Test Post\",\n  \"body\": \"This is a test post body\",\n  \"userId\": 1\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/posts",
          "host": ["{{base_url}}"],
          "path": ["posts"]
        },
        "description": "Create a new post with JSON body"
      }
    },
    {
      "name": "Update Post",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": 1,\n  \"title\": \"Updated Title\",\n  \"body\": \"Updated body content\",\n  \"userId\": 1\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/posts/1",
          "host": ["{{base_url}}"],
          "path": ["posts", "1"]
        },
        "description": "Update an existing post"
      }
    },
    {
      "name": "Delete Post",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/posts/1",
          "host": ["{{base_url}}"],
          "path": ["posts", "1"]
        },
        "description": "Delete a post by ID"
      }
    }
  ]
}
