{
  "info": {
    "name": "ACE Import Test — Intermediate",
    "_postman_id": "ace-test-intermediate-002",
    "description": "Intermediate collection to test ACE import. Includes token chaining, pre-request scripts, test scripts, and folder structure.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://jsonplaceholder.typicode.com"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "user_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Simulate setting credentials before request",
                  "pm.variables.set('email', 'test@example.com');",
                  "pm.variables.set('password', 'hunter2');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has id', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.id).to.exist;",
                  "});",
                  "",
                  "// Extract and store token (simulated)",
                  "var json = pm.response.json();",
                  "pm.environment.set('token', 'Bearer simulated-token-' + json.id);",
                  "pm.environment.set('user_id', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"title\": \"Login Request\",\n  \"userId\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/posts",
              "host": ["{{base_url}}"],
              "path": ["posts"]
            },
            "description": "Simulated login — extracts token and user_id for use in subsequent requests"
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Get User Profile",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Ensure token exists before making request",
                  "var token = pm.environment.get('token');",
                  "if (!token) {",
                  "    throw new Error('Token is missing. Run Login first.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response time is acceptable', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(500);",
                  "});",
                  "",
                  "pm.test('Has userId field', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.userId).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{token}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/posts/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{user_id}}"]
            },
            "description": "Fetch user profile using token and user_id extracted from login"
          }
        },
        {
          "name": "Update User Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Title was updated', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.title).to.equal('Updated Profile');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "{{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": {{user_id}},\n  \"title\": \"Updated Profile\",\n  \"body\": \"Updated bio\",\n  \"userId\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/posts/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{user_id}}"]
            },
            "description": "Update user profile using token from login"
          }
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "Get All Posts",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Returns array', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.be.an('array');",
                  "});",
                  "",
                  "// Extract first post id for next request",
                  "var json = pm.response.json();",
                  "if (json.length > 0) {",
                  "    pm.environment.set('first_post_id', json[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/posts?userId={{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["posts"],
              "query": [
                {
                  "key": "userId",
                  "value": "{{user_id}}"
                }
              ]
            },
            "description": "Get all posts for the logged in user, extracts first_post_id"
          }
        },
        {
          "name": "Get Post Comments",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Comments is array', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/posts/{{first_post_id}}/comments",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{first_post_id}}", "comments"]
            },
            "description": "Get comments for a post using first_post_id extracted from previous step"
          }
        }
      ]
    }
  ]
}
